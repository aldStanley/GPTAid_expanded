        unsigned short minor_version = 4;
        unsigned int snaplen = 65535; // max snapshot length
        unsigned int network = 1;    // network type (e.g., 1 for Ethernet)
        fwrite(&magic_number, sizeof(magic_number), 1, fp);
        fwrite(&major_version, sizeof(major_version), 1, fp);
        fwrite(&minor_version, sizeof(minor_version), 1, fp);
        fwrite(&snaplen, sizeof(snaplen), 1, fp);
        fwrite(&network, sizeof(network), 1, fp);
        fclose(fp);
        printf("Created dummy file: %s\n", OFFLINE_FILENAME);
        fflush(stdout);
    } else {
        fclose(fp);
    }

    handle = pcap_open_offline(OFFLINE_FILENAME, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Error opening offline capture file %s: %s\n", OFFLINE_FILENAME, errbuf);
        fflush(stdout);
        return 123;
    }
    printf("Successfully opened offline capture file: %s\n", OFFLINE_FILENAME);
    fflush(stdout);

    // --- Part 2: Call pcap_next_ex ---
    printf("before pcap_next_ex\n");
    fflush(stdout);

    // We'll try to read just one packet to avoid infinite loops
    int ret = pcap_next_ex(handle, &packet_header, &packet_data);

    // --- Part 3: Check the return status ---
    if (ret == 1) {
        // Packet successfully read
        printf("Calling pcap_next_ex success\n");
        fflush(stdout);
        packet_count++;
        printf("Packet #%d captured: %u bytes\n", packet_count, packet_header->len);
        fflush(stdout);
        // In a real application, you would process packet_data here.
        // For this example, we'll just print a confirmation.
        printf("Packet data pointer: %p\n", (void *)packet_data);
        fflush(stdout);
    } else if (ret == 0) {
        // Timeout (for live capture) or EOF (mapped from pcap_offline_read)
        fprintf(stderr, "pcap_next_ex returned 0. This usually means a timeout in live capture or EOF in offline capture.\n");
        fflush(stdout);
        // For offline capture, ret == -2 is the specific EOF return.
        // If ret == 0 here, it implies a timeout for live capture which we are not demonstrating with this example.
        // If it were a live capture and this happened, you might want to try again.
        printf("Calling pcap_next_ex fail\n");
        fflush(stdout);
        // Since we are limiting to one packet and it's offline, ret == 0 won't happen for EOF.
        // But if it did, it would be a failure to get a packet.
        return 123;
    } else if (ret == -1) {
        // Error occurred
        fprintf(stderr, "Error in pcap_next_ex: %s\n", pcap_geterr(handle));
        fflush(stdout);
        printf("Calling pcap_next_ex fail\n");
        fflush(stdout);
        pcap_close(handle);
        return 123;
    } else if (ret == -2) {
        // EOF reached in offline capture or breakloop
        printf("End of file reached in capture file or loop was broken.\n");
        fflush(stdout);
        printf("Calling pcap_next_ex fail\n");
        fflush(stdout);
        // For offline capture, -2 signifies EOF, which is not an error but an end of data.
        // If this is the *only* operation and we expected a packet, it's a failure for this call.
        pcap_close(handle);
        return 0; // Exiting normally after EOF if no packet was expected beyond this.
    } else {
        // Unexpected return code
        fprintf(stderr, "pcap_next_ex returned an unexpected value: %d\n", ret);
        fflush(stdout);
        printf("Calling pcap_next_ex fail\n");
        fflush(stdout);
        pcap_close(handle);
        return 123;
    }

    // --- Part 4: Cleanup ---
    pcap_close(handle);
    printf("Pcap handle closed.\n");
    fflush(stdout);

    return 0;
}
