        // Create a minimal valid pcap file for demonstration purposes.
        // This is a very basic header for a pcap file with no packets.
        // A real pcap file would have more structure.
        fp = fopen(OFFLINE_FILENAME, "wb");
        if (fp == NULL) {
            fprintf(stderr, "Failed to create dummy pcap file: %s\n", strerror(errno));
            fflush(stdout);
            return 123;
