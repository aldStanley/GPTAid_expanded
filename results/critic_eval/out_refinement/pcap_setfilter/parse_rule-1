    char errbuf[PCAP_ERRBUF_SIZE]; // Error buffer for pcap functions
    char *interface = "eth0"; // Example interface, change if needed
    char *filter_exp = "tcp port 80"; // Example filter expression

    // 1. Initialize pcap_t handle
