int pcap_parsesrcstr_ex(const char *source, int *type, char *userinfo, char *host,
    char *port, char *name, unsigned char *uses_ssl, char *errbuf){
	char *scheme, *tmpuserinfo, *tmphost, *tmpport, *tmppath;

