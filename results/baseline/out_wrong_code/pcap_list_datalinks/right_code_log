pcap_t *pcap_open_live(const char *device, int snaplen, int promisc, int to_ms, char *errbuf) {
    // Simulate a successful open for demonstration
    pcap_t *p = (pcap_t *)malloc(sizeof(pcap_t));
    if (p == NULL) {
        snprintf(errbuf, PCAP_ERRBUF_SIZE, "malloc failed: %s", strerror(errno));
        return NULL;
    }
    p->activated = 1;
    p->dlt_count = 3; // Simulate multiple DLTs
    p->linktype = 1;  // Simulate a default link type
    p->dlt_list = (int *)malloc(sizeof(int) * p->dlt_count);
    if (p->dlt_list == NULL) {
        snprintf(errbuf, PCAP_ERRBUF_SIZE, "malloc failed for dlt_list: %s", strerror(errno));
        free(p);
        return NULL;
