        fflush(stdout);
        fprintf(stderr, "pcap_major_version failed with error code: %d\n", major_version);
        fflush(stdout);
        // Clean up the pcap handle
        pcap_close(handle);
        return 123;
    } else {
        printf("Calling pcap_major_version success\n");
        fflush(stdout);
        printf("Libpcap major version: %d\n", major_version);
        fflush(stdout);
    }

    // Clean up the pcap handle
    pcap_close(handle);
