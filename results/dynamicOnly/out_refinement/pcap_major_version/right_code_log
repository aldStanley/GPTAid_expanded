        printf("Calling pcap_major_version success\n");
        fflush(stdout);
        printf("Libpcap major version: %d\n", major_version);
        fflush(stdout);
    }

    // Clean up the pcap handle
    pcap_close(handle);
    printf("pcap_close successful.\n");
    fflush(stdout);

    return 0;
}
