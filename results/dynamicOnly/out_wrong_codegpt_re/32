#include <pcap.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <errno.h>

#define EXIT_FAILURE_CUSTOM 123

int main() {
    pcap_t *handle;
    char errbuf[PCAP_ERRBUF_SIZE];
    struct pcap_pkthdr *header;
    const u_char *packet;
    int pkt_count = 0;

    /*
     * Open a live capture device. Replace "eth0" with your actual network interface name.
     * If you don't have a live interface readily available or want to test with a file,
     * you could use pcap_open_offline("example.pcap", errbuf) instead.
     */
    handle = pcap_open_live("eth0", BUFSIZ, 1, 1000, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Couldn't open device: %s\n", errbuf);
        fflush(stdout);
        return EXIT_FAILURE_CUSTOM;
    }
    printf("Successfully opened network interface.\n");
    fflush(stdout);

    // Prepare pointers for pcap_next_ex
    struct pcap_pkthdr *header_ptr = NULL;
    const u_char **packet_ptr = (const u_char **)malloc(sizeof(const u_char *));
    if (packet_ptr == NULL) {
        fprintf(stderr, "Memory allocation failed for packet_ptr.\n");
        fflush(stdout);
        pcap_close(handle);
        return EXIT_FAILURE_CUSTOM;
    }

    printf("before pcap_next_ex\n");
    fflush(stdout);

    int status = pcap_next_ex(handle, &header_ptr, (const u_char **)packet_ptr);

    if (status > 0) {
        // Packet captured successfully
        printf("Calling pcap_next_ex success\n");
        fflush(stdout);
        pkt_count++;
        header = header_ptr;
        packet = *packet_ptr;

        printf("Packet %d captured: %u bytes\n", pkt_count, header->len);
        fflush(stdout);

        // Example of accessing packet data (e.g., first few bytes)
        printf("First 10 bytes of packet data: ");
        fflush(stdout);
        for (int i = 0; i < header->len && i < 10; i++) {
            printf("%02x ", packet[i]);
            fflush(stdout);
        }
        printf("\n");
        fflush(stdout);
    } else if (status == 0) {
        // Timeout occurred (for live captures)
        printf("Calling pcap_next_ex fail (timeout)\n");
        fflush(stdout);
    } else if (status == -1) {
        // Error occurred
        fprintf(stderr, "Calling pcap_next_ex fail (error): %s\n", pcap_geterr(handle));
        fflush(stdout);
        pcap_close(handle);
        free(packet_ptr);
        return EXIT_FAILURE_CUSTOM;
    } else if (status == -2) {
        // EOF occurred (for offline captures) or breakloop called
        printf("Calling pcap_next_ex fail (EOF or breakloop)\n");
        fflush(stdout);
    }

    // Clean up
    pcap_close(handle);
    free(packet_ptr);
    printf("Pcap handle closed and memory freed.\n");
    fflush(stdout);

    if (pkt_count > 0) {
        return 0; // Success
    } else {
        return EXIT_FAILURE_CUSTOM; // Indicate failure if no packet was captured and it wasn't a timeout/EOF
    }
}
