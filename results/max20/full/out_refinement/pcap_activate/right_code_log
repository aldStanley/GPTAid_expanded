        // If pcap_activate failed, it might have partially initialized
        // the handle. Cleanup is usually handled by pcap_close, but
        // if pcap_activate itself failed badly, the handle might be invalid.
        // In many cases, pcap_close is still safe to call.
        if (handle) {
             pcap_close(handle);
        }
        return 123;
    }

    return 0;
}
