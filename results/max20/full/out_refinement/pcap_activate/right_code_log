        printf("Calling pcap_activate fail\n");
        fflush(stdout);
        // If activation failed, the errbuf in the handle might have details
        // or pcap_statustostr(status) will provide the generic error.
        if (errbuf[0] == '\0') {
            fprintf(stderr, "pcap_activate failed with status %d: %s\n", status, pcap_statustostr(status));
            fflush(stderr);
        } else {
            fprintf(stderr, "pcap_activate failed: %s\n", errbuf);
            fflush(stderr);
