    #include <stdio.h>

    int main() {
        pcap_t *handle = NULL; // handle is not activated
        int *dlt_list = NULL;
        int num_dlts;

        // Attempt to list datalinks on an unactivated handle
        num_dlts = pcap_list_datalinks(handle, &dlt_list);

        if (num_dlts == PCAP_ERROR_NOT_ACTIVATED) {
            fprintf(stderr, "Error: pcap_list_datalinks failed because the pcap handle was not activated.\n");
        } else if (num_dlts < 0) {
