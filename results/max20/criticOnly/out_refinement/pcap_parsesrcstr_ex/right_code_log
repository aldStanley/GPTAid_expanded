    size_t srclen;

    // If dstsize is 0, then no characters can be copied.
    if (dstsize == 0)
        return (0);

    // Determine the length of the source string.
    srclen = strlen(src);

    // If the source string is longer than the destination buffer,
    // truncate the source string to fit.
    if (srclen >= dstsize) {
        srclen = dstsize - 1;
        // Copy only as many characters as will fit in the destination buffer.
        memcpy(dst, src, srclen);
        dst[srclen] = '\0'; // Ensure null termination.
