    // Using a very large number, unlikely to be a valid error code.
    // This tests the fallback "Unknown error" path if HAVE_STRERROR is not defined,
    // or if the system's strerror handles invalid inputs gracefully.
    error_code_to_test = 999999;

    printf("before pcap_strerror\n");
    fflush(stdout);

    error_message = pcap_strerror(error_code_to_test);

    if (error_message == NULL) {
        fprintf(stderr, "Calling pcap_strerror fail.\n");
        fflush(stderr);
        return 123;
    } else {
        printf("Calling pcap_strerror success\n");
        printf("Error description for code %d: %s\n", error_code_to_test, error_message);
        fflush(stdout);
    }

    // --- Test Case 3: Simulating a pcap function failure and getting its error ---
    // This is more complex as we need a real pcap error.
