        // For this task, we'll focus on interpreting errno if it's set by pcap functions.
        // If pcap_open_live fails, it often sets errno.
        error_code_to_test = errno; // Get the system error code that caused pcap_open_live to fail.

        printf("before pcap_strerror\n");
        fflush(stdout);

        error_message = pcap_strerror(error_code_to_test);

        if (error_message == NULL) {
            fprintf(stderr, "Calling pcap_strerror fail.\n");
            fflush(stderr);
            return 123;
        } else {
            printf("Calling pcap_strerror success\n");
            printf("Interpreting errno (%d) after pcap_open_live failure: %s\n", error_code_to_test, error_message);
            fflush(stdout);
        }
        // Clean up the error buffer from pcap_open_live
        printf("pcap_open_live failed, error: %s\n", errbuf);
        fflush(stdout);
    } else {
        // This case should ideally not be reached if the interface truly doesn't exist.
        printf("Unexpected success opening a non-existent interface. Skipping errno test.\n");
        fflush(stdout);
        pcap_close(handle);
    }

    return 0;
}
