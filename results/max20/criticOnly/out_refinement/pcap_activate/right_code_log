#define PCAP_ERRBUF_SIZE 256 // Standard size for error buffer

int main() {
    char errbuf[PCAP_ERRBUF_SIZE];
    pcap_t *handle = NULL;
    int status;

    // Initialize error buffer
    errbuf[0] = '\0';

    // --- Step 1: Find a suitable network interface ---
    // We need a valid network interface to open.
    // pcap_findalldevs() is used to list available devices.
    pcap_if_t *alldevs;
    if (pcap_findalldevs(&alldevs, errbuf) == -1) {
        fprintf(stderr, "Error finding all devices: %s\n", errbuf);
        fflush(stdout);
        return 123;
    }

    char *device_to_open = NULL;
    pcap_if_t *d = alldevs;

    // Iterate through devices to find a suitable one.
    // We'll prefer a loopback or an UP and RUNNING interface.
    while (d != NULL) {
        // Check if the device is usable (not a virtual interface for simulation, etc.)
        if (d->flags & PCAP_IF_UP && !(d->flags & PCAP_IF_LOOPBACK) && (d->flags & PCAP_IF_RUNNING)) {
             // Check if the interface has an IPv4 address (common for active interfaces)
            struct pcap_addr *a = d->addresses;
            while (a != NULL) {
                if (a->addr->sa_family == AF_INET) { // Check for IPv4
                    device_to_open = d->name;
                    break;
                }
                a = a->next;
            }
        }
        if (device_to_open) break; // Found a suitable device
        d = d->next;
    }

    // If no suitable device is found, try the loopback interface
    if (device_to_open == NULL) {
        d = alldevs;
        while (d != NULL) {
            if (d->flags & PCAP_IF_LOOPBACK) {
                device_to_open = d->name;
                break;
            }
            d = d->next;
        }
    }

    // If still no device found, exit
    if (device_to_open == NULL) {
        fprintf(stderr, "No suitable network interface found.\n");
        fflush(stdout);
        pcap_freealldevs(alldevs); // Free the list of devices
        return 123;
    }

    printf("Attempting to open device: %s\n", device_to_open);
    fflush(stdout);

    // Open the selected device for live capture
