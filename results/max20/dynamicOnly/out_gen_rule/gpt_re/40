        // For demonstration, we'll simulate an unactivated handle
        // In a real scenario, 'handle' would be obtained from pcap_open_live or similar.
        struct pcap_t {
            int activated;
            struct {
                int timeout;
            } opt;
            char errbuf[PCAP_ERRBUF_SIZE];
        } simulated_handle;
        simulated_handle.activated = 0; // Ensure it's not activated
        handle = (pcap_t*)&simulated_handle;

        int negative_timeout = -100; // Invalid negative timeout

        // Violation: Calling pcap_set_timeout with a negative value
