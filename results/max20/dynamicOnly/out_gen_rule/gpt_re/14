        if (sub) {
            memcpy(sub, str, len);
            sub[len] = '\0';
        } else {
            snprintf(ebuf, PCAP_ERRBUF_SIZE, "malloc failed");
        }
        return sub;
    }

    int pcap_strlcpy(char *dst, const char *src, size_t size) {
        size_t len = strlen(src);
        if (len >= size) {
            len = size - 1;
        }
        memcpy(dst, src, len);
        dst[len] = '\0';
        return len;
    }

    int pcap_strcasecmp(const char *s1, const char *s2) {
        return strcasecmp(s1, s2);
    }

    int pcap_fmt_errmsg_for_errno(char *errbuf, size_t errbuf_size, int errno_val, const char *fmt, ...) {
        va_list ap;
        va_start(ap, fmt);
        int ret = vsnprintf(errbuf, errbuf_size, fmt, ap);
        va_end(ap);
        if (ret < 0 || (size_t)ret >= errbuf_size) {
            errbuf[errbuf_size - 1] = '\0';
        }
        return ret;
    }

