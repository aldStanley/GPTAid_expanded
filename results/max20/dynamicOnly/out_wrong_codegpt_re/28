            fprintf(stderr, "Error message: %s (status code: %d)\n", pcap_statustostr(status), status);
            fflush(stdout);
        } else {
            fprintf(stderr, "Error message: %s\n", errbuf);
            fflush(stdout);
        }
        // Cleanup is handled by pcap_close in this specific example.
        pcap_close(handle);
        return CUSTOM_EXIT_FAILURE;
    }

    // Task2.2: Non-interactive, no infinite loops.
    // For this example, we just perform a single capture or demonstrate activation.
    // In a real scenario, you'd loop to capture packets.

    // Task2.3: Check API call status.
