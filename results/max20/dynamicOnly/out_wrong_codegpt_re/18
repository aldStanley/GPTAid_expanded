#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include <pcap.h>


int main() {
    pcap_t *handle = NULL;
    char errbuf[PCAP_ERRBUF_SIZE];
    int *dlt_list = NULL;
    int num_datalinks = 0;
    char *device = NULL; // Use char* for device name as pcap_findalldevs returns char*

    // Use pcap_findalldevs to get a list of devices as pcap_lookupdev is deprecated.
    pcap_if_t *alldevs;
    if (pcap_findalldevs(&alldevs, errbuf) == -1) {
        fprintf(stderr, "Couldn't find any devices: %s\n", errbuf);
        fflush(stderr);
        return 123;
    }

    if (alldevs == NULL) {
        fprintf(stderr, "No network devices found.\n");
        fflush(stderr);
        return 123;
    }
    device = alldevs->name; // Use the first device found
    printf("Using network device: %s\n", device);
    fflush(stdout);

    // Open a live capture handle
    // Increased snaplen to 65535 for better packet capture
    handle = pcap_open_live(device, 65535, 1, 1000, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Couldn't open device %s: %s\n", device, errbuf);
        fflush(stderr);
        pcap_freealldevs(alldevs); // Free the list of devices
        return 123;
    }
    printf("Successfully opened device %s\n", device);
    fflush(stdout);

    // To activate the device for pcap_list_datalinks, we need to set a filter.
    // A common practice is to set an empty filter to capture all packets,
    // which effectively activates the device for listing DLTs without filtering.
    struct bpf_program fp; // Structure to hold compiled filter code
    // The filter string "" means no filter, i.e., capture all packets.
    if (pcap_compile(handle, &fp, "", 1, 0) == -1) {
        fprintf(stderr, "Couldn't parse filter: %s\n", pcap_geterr(handle));
        fflush(stderr);
        pcap_freealldevs(alldevs); // Free the list of devices
        pcap_close(handle);
        return 123;
    }

    if (pcap_setfilter(handle, &fp) == -1) {
        fprintf(stderr, "Couldn't install filter: %s\n", pcap_geterr(handle));
        fflush(stderr);
        pcap_freecode(&fp); // Free the compiled filter
        pcap_freealldevs(alldevs); // Free the list of devices
        pcap_close(handle);
        return 123;
    }
    pcap_freecode(&fp); // Free the compiled filter after successful installation
    printf("Device activated by setting an empty filter.\n");
    fflush(stdout);

    // The pcap_list_datalinks function expects a pointer to a pointer to an int.
    // We need to allocate memory for this pointer.
    int **dlt_buffer_ptr = (int **)malloc(sizeof(int *));
    if (dlt_buffer_ptr == NULL) {
        fprintf(stderr, "Failed to allocate memory for dlt_buffer_ptr: %s\n", strerror(errno));
        fflush(stderr);
        pcap_freealldevs(alldevs); // Free the list of devices
        pcap_close(handle);
        return 123;
    }
    *dlt_buffer_ptr = NULL; // Initialize the inner pointer to NULL

    printf("before pcap_list_datalinks\n");
    fflush(stdout);

    // Call pcap_list_datalinks
    num_datalinks = pcap_list_datalinks(handle, dlt_buffer_ptr);

    if (num_datalinks < 0) {
        printf("Calling pcap_list_datalinks fail\n");
        fflush(stdout);
        fprintf(stderr, "pcap_list_datalinks failed: %s\n", pcap_geterr(handle));
        fflush(stderr);
        // According to the libpcap documentation, if pcap_list_datalinks returns an error,
        // the memory pointed to by dlt_buffer will not be allocated or will be invalid.
        // We should free the pointer-to-pointer we allocated, but not the inner pointer
        // as it's not guaranteed to be valid or allocated by pcap_list_datalinks.
        free(dlt_buffer_ptr);
        pcap_freealldevs(alldevs); // Free the list of devices
        pcap_close(handle);
        return 123;
    } else {
        printf("Calling pcap_list_datalinks success\n");
        fflush(stdout);

        dlt_list = *dlt_buffer_ptr; // Dereference the pointer to pointer

        printf("Number of data link types supported: %d\n", num_datalinks);
        fflush(stdout);

        printf("Supported data link types:\n");
        fflush(stdout);
        for (int i = 0; i < num_datalinks; ++i) {
            // pcap_datalink_val_to_name is used to get a human-readable name for the DLT
            const char* dlt_name = pcap_datalink_val_to_name(dlt_list[i]);
            if (dlt_name != NULL) {
                printf("  DLT: %d (%s)\n", dlt_list[i], dlt_name);
            } else {
                printf("  DLT: %d (Unknown)\n", dlt_list[i]);
            }
            fflush(stdout);
        }

        // Free the allocated buffer pointed to by dlt_buffer_ptr
        free(dlt_list);
        dlt_list = NULL; // Set to NULL after freeing to prevent double free
    }

    // Free the pointer-to-pointer allocation
    free(dlt_buffer_ptr);
    dlt_buffer_ptr = NULL;

    // Close the pcap handle
    pcap_close(handle);
    printf("Closed pcap handle.\n");
    fflush(stdout);

    // Free the list of devices
    pcap_freealldevs(alldevs);
    printf("Freed device list.\n");
    fflush(stdout);

    return 0;
}



