    // Increased snaplen to 65535 for better packet capture
    handle = pcap_open_live(device, 65535, 1, 1000, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Couldn't open device %s: %s\n", device, errbuf);
        fflush(stderr);
        return 123;
    }
    printf("Successfully opened device %s\n", device);
    fflush(stdout);

    // To activate the device for pcap_list_datalinks, we need to set a filter.
    // A common practice is to set an empty filter to capture all packets,
    // which effectively activates the device for listing DLTs without filtering.
    struct bpf_program fp; // Structure to hold compiled filter code
    // The filter string "" means no filter, i.e., capture all packets.
    if (pcap_compile(handle, &fp, "", 1, 0) == -1) {
        fprintf(stderr, "Couldn't parse filter: %s\n", pcap_geterr(handle));
        fflush(stderr);
        pcap_close(handle);
        return 123;
    }

    if (pcap_setfilter(handle, &fp) == -1) {
        fprintf(stderr, "Couldn't install filter: %s\n", pcap_geterr(handle));
        fflush(stderr);
        pcap_freecode(&fp); // Free the compiled filter
        pcap_close(handle);
        return 123;
    }
    pcap_freecode(&fp); // Free the compiled filter after successful installation
    printf("Device activated by setting an empty filter.\n");
    fflush(stdout);

    int **dlt_buffer_ptr = NULL; // Initialize pointer to pointer to NULL

    printf("before pcap_list_datalinks\n");
    fflush(stdout);

    // Call pcap_list_datalinks
    num_datalinks = pcap_list_datalinks(handle, &dlt_buffer_ptr);

    if (num_datalinks < 0) {
        printf("Calling pcap_list_datalinks fail\n");
        fflush(stdout);
        fprintf(stderr, "pcap_list_datalinks failed: %s\n", pcap_geterr(handle));
        fflush(stderr);
        pcap_close(handle);
        // The specification of pcap_list_datalinks states that if it fails,
        // dlt_buffer is not guaranteed to be populated or even allocated.
        // However, if it were somehow allocated, the caller would be responsible for freeing.
        // In this case, num_datalinks < 0 indicates an error, and we don't expect
        // dlt_buffer_ptr to be validly pointing to allocated memory from pcap_list_datalinks.
        // Thus, explicit freeing here after failure might not be strictly necessary based on
        // typical libpcap error handling, but checking for NULL is good practice.
        if (*dlt_buffer_ptr != NULL) {
             free(*dlt_buffer_ptr);
        }
        return 123;
    } else {
        printf("Calling pcap_list_datalinks success\n");
        fflush(stdout);

        dlt_list = *dlt_buffer_ptr; // Dereference the pointer to pointer

        printf("Number of data link types supported: %d\n", num_datalinks);
        fflush(stdout);

        printf("Supported data link types:\n");
        fflush(stdout);
        for (int i = 0; i < num_datalinks; ++i) {
            // pcap_datalink_val_to_name is used to get a human-readable name for the DLT
            const char* dlt_name = pcap_datalink_val_to_name(dlt_list[i]);
            if (dlt_name != NULL) {
                printf("  DLT: %d (%s)\n", dlt_list[i], dlt_name);
            } else {
                printf("  DLT: %d (Unknown)\n", dlt_list[i]);
            }
            fflush(stdout);
        }

        // Free the allocated buffer
        free(dlt_list);
        dlt_list = NULL; // Set to NULL after freeing to prevent double free
    }

    // Close the pcap handle
    pcap_close(handle);
    printf("Closed pcap handle.\n");
    fflush(stdout);

    return 0;
}



