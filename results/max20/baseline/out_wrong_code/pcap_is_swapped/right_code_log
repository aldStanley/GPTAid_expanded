#include <string.h>
#include <pcap.h>
#include <errno.h> // Added for errno and strerror

// Define a dummy device for demonstration if needed, or let pcap_open_live find one.
// For this example, we'll try to find a device.
#ifndef PCAP_DEFAULT_DEV
#define PCAP_DEFAULT_DEV "eth0" // A common default, may need adjustment
#endif

int main() {
    char errbuf[PCAP_ERRBUF_SIZE];
    pcap_t *handle = NULL; // Initialize handle to NULL
    int swapped_result;

    // Attempt to open a live capture handle. This is necessary to activate the handle.
    handle = pcap_open_live(PCAP_DEFAULT_DEV, BUFSIZ, 1, 1000, errbuf);
    if (handle == NULL) {
        // If opening live fails, try opening an offline file to get an activated handle.
        // This satisfies the 'activated' requirement for pcap_is_swapped.
        // Using a dummy file name as per instructions.
        const char *filename = "example.pcap"; // xxx replaced with pcap

        // Create a dummy file if it doesn't exist, just to have something to open.
        // In a real scenario, this file would contain pcap data.
        FILE *dummy_file = fopen(filename, "w");
        if (dummy_file == NULL) {
            fprintf(stderr, "Failed to create dummy pcap file '%s': %s\n", filename, strerror(errno));
            fflush(stderr);
            // Still try to open the file even if creation failed, pcap_open_offline might handle it.
        } else {
            fclose(dummy_file);
        }

        handle = pcap_open_offline(filename, errbuf);
        if (handle == NULL) {
            fprintf(stderr, "Error opening offline capture file '%s': %s\n", filename, errbuf);
            fflush(stderr);
            fprintf(stderr, "Could not activate pcap handle using live or offline. Cannot call pcap_is_swapped.\n");
            fflush(stderr);
            return 123;
        } else {
            printf("Successfully opened pcap handle from offline file '%s'.\n", filename);
            fflush(stdout);
        }
    } else {
        printf("Successfully opened live pcap handle on device '%s'.\n", PCAP_DEFAULT_DEV);
        fflush(stdout);
    }

    // At this point, 'handle' should be an activated pcap handle.

    printf("before pcap_is_swapped\n");
    fflush(stdout);

    swapped_result = pcap_is_swapped(handle);

    if (swapped_result < 0) { // pcap_is_swapped returns PCAP_ERROR_NOT_ACTIVATED (-1) if not activated
        fprintf(stderr, "Calling pcap_is_swapped fail. Returned value: %d\n", swapped_result);
        fflush(stderr);
        // If the error is PCAP_ERROR_NOT_ACTIVATED, it means the handle wasn't activated.
        // This should ideally not happen if we reached this point successfully.
        if (swapped_result == PCAP_ERROR_NOT_ACTIVATED) {
            fprintf(stderr, "Reason: The pcap handle was not activated. This is unexpected.\n");
            fflush(stderr);
        } else {
            // Other potential negative return values from libpcap functions.
            fprintf(stderr, "An unexpected error occurred with pcap_is_swapped. The return value indicates an error.\n");
            fflush(stderr);
        }
        pcap_close(handle); // Close the handle before exiting
        return 123;
    } else {
        printf("Calling pcap_is_swapped success\n");
        fflush(stdout);
        if (swapped_result == 1) {
            printf("The pcap data's byte order is different from the system's.\n");
            fflush(stdout);
        } else {
            printf("The pcap data's byte order matches the system's.\n");
            fflush(stdout);
        }
    }

    pcap_close(handle); // Close the pcap handle
    printf("Pcap handle closed.\n");
    fflush(stdout);

    return 0;
}
