            // Timeout (live capture) or EOF (offline capture)
            if (pcap_getmode(handle) == PCAP_MODE_LIVE) {
                printf("pcap_next_ex: Timeout occurred (no packets arrived).\n");
                fflush(stdout);
                // In a real application, you might want to continue listening
