                break;
            } else {
                printf("pcap_next_ex: End of file reached in offline capture.\n");
                fflush(stdout);
                break; // Exit loop after EOF
            }
        } else if (status == -1) {
            // Error
            fprintf(stderr, "Calling pcap_next_ex fail\n");
            fflush(stderr);
            fprintf(stderr, "pcap_next_ex error: %s\n", pcap_geterr(handle));
            fflush(stderr);
            pcap_close(handle);
            return 123; // Exit with error code
        } else if (status == -2) {
            // EOF in offline capture (explicitly mapped by pcap_next_ex)
            printf("pcap_next_ex: End of file reached (returned -2).\n");
            fflush(stdout);
            break; // Exit loop after EOF
        } else if (status == -3) {
            // Break loop
            printf("pcap_next_ex: Capture loop was broken by pcap_breakloop().\n");
            fflush(stdout);
            break;
        } else {
            // Unexpected return value
            fprintf(stderr, "Calling pcap_next_ex fail\n");
            fflush(stderr);
            fprintf(stderr, "pcap_next_ex returned unexpected status code: %d\n", status);
            fflush(stderr);
            pcap_close(handle);
            return 123; // Exit with error code
        }
    }

    // Close the pcap handle
    pcap_close(handle);
    printf("Pcap handle closed.\n");
    fflush(stdout);

    return 0;
}
