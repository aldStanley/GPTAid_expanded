// Function to simulate creating a dummy pcap file for testing
// In a real scenario, you'd have an actual .pcap file.
void create_dummy_pcap_file(const char *filename) {
    pcap_t *out_pcap;
    char errbuf[PCAP_ERRBUF_SIZE];
    struct pcap_pkthdr header;
    const u_char packet_data[] = {
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d, 0x0e, 0x0f
    };

    out_pcap = pcap_open_dead(DLT_EN10MB, sizeof(packet_data));
    if (!out_pcap) {
        fprintf(stderr, "Error creating dummy pcap handle: %s\n", pcap_geterr(out_pcap));
        return;
    }

    FILE *outfile = fopen(filename, "wb");
    if (!outfile) {
        fprintf(stderr, "Error opening file %s for writing: %s\n", filename, strerror(errno));
        pcap_close(out_pcap);
        return;
    }

    if (pcap_dump_open(out_pcap, filename) == NULL) {
        fprintf(stderr, "Error opening dump file %s: %s\n", filename, pcap_geterr(out_pcap));
        fclose(outfile);
        pcap_close(out_pcap);
        return;
    }

    // Fill header (simplified for demonstration)
    header.ts.tv_sec = 1678886400; // Example timestamp
    header.ts.tv_usec = 123456;
    header.caplen = sizeof(packet_data);
    header.len = sizeof(packet_data);

    // Write one packet
    pcap_dump((unsigned char *)pcap_file_buffer(out_pcap), &header, packet_data);

    pcap_dump_close(pcap_file_buffer(out_pcap));
    fclose(outfile); // Close the file stream that pcap_dump_open internally opened
    pcap_close(out_pcap);
    printf("Dummy pcap file '%s' created with one packet.\n", filename);
    fflush(stdout);
}


