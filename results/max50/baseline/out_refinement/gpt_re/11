    }

    printf("Calling pcap_setfilter success\n");
    fflush(stdout);

    // 4. Cleanup
    pcap_freecode(&fp); // Free the compiled filter
    pcap_close(handle); // Close the pcap handle
    printf("Pcap handle closed and filter freed.\n");
    fflush(stdout);

    return 0; // Success
}


