        fflush(stdout);
        num_datalinks = result;

        printf("Successfully retrieved %d data link types.\n", num_datalinks);
        fflush(stdout);

        // --- Step 4: Process the retrieved datalinks ---
        printf("Data link types:\n");
        fflush(stdout);
        for (int i = 0; i < num_datalinks; i++) {
