#include <pcap.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <errno.h>

// Function to print error messages and exit
void print_error_and_exit(const char *message, const char *api_name) {
    fprintf(stderr, "%s: %s - %s\n", message, api_name, pcap_geterr(NULL)); // Use NULL for general pcap errors if no handle yet
    fflush(stdout);
    exit(123);
}

// Helper to print error messages for pcap_open_live
void print_pcap_open_error(const char *message, const char *device) {
    fprintf(stderr, "%s: %s - %s\n", message, device, pcap_geterr(NULL));
    fflush(stdout);
    exit(123);
}

// Helper to print error messages for pcap_compile
void print_pcap_compile_error(const char *message, const char *filter_exp) {
    fprintf(stderr, "%s: %s - %s\n", message, filter_exp, pcap_geterr(NULL));
    fflush(stdout);
    exit(123);
