            fflush(stdout);
            return 123;
        }
        device_name = default_dev;
        printf("Using default device: %s\n", device_name);
        fflush(stdout);
    }

    printf("before pcap_create\n");
    fflush(stdout);

    handle = pcap_create(device_name, errbuf);

    if (handle == NULL) {
