            snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for scheme");
            return -1;
        }
        ptr += 7;
    } else if (strncmp(ptr, "rpcap://", 8) == 0) {
        *scheme = strdup("rpcap");
        if (!*scheme) {
            snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for scheme");
            return -1;
        }
        ptr += 8;
    } else if (strncmp(ptr, "rpcaps://", 9) == 0) {
        *scheme = strdup("rpcaps");
        if (!*scheme) {
            snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for scheme");
            return -1;
        }
        ptr += 9;
    }

    // Parse userinfo, host, port, and path based on scheme
    if (*scheme) {
        // For remote capture, we need to parse host, port, and potentially userinfo
        // This mock is highly simplified and doesn't handle complex URIs.
        char *end_ptr = NULL;
        char *auth_part = NULL;

        if (strcmp(*scheme, "file") == 0) {
            *path = strdup(ptr);
            if (!*path) {
                snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for path");
                return -1;
            }
        } else { // rpcap or rpcaps
            // Look for userinfo part
            char *at_sign = strchr(ptr, '@');
            if (at_sign) {
                auth_part = strndup(ptr, at_sign - ptr);
                if (!auth_part) {
                    snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for auth_part");
                    return -1;
                }
                ptr = at_sign + 1;
            }

            // Look for port part
            char *colon = strchr(ptr, ':');
            if (colon) {
                *port = strdup(colon + 1);
                if (!*port) {
                    snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for port");
                    free(auth_part);
                    return -1;
                }
                end_ptr = colon;
            } else {
                end_ptr = ptr + strlen(ptr);
            }
            *host = strndup(ptr, end_ptr - ptr);
            if (!*host) {
                snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for host");
                free(auth_part);
                free(*port);
                *port = NULL;
                return -1;
            }

            if (auth_part) {
                // Simple parsing: assume "user:pass"
                char *pass_colon = strchr(auth_part, ':');
                if (pass_colon) {
                    *userinfo = strdup(auth_part); // Store the whole auth part
                    if (!*userinfo) {
                        snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for userinfo");
                        free(auth_part);
                        free(*host);
                        free(*port);
                        return -1;
                    }
                } else {
                    *userinfo = strdup(auth_part); // Just username
                    if (!*userinfo) {
                        snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for userinfo");
                        free(auth_part);
                        free(*host);
                        free(*port);
                        return -1;
                    }
                }
                free(auth_part);
            }

            // For rpcap[s], the rest is often treated as the device name
            if (strlen(ptr) > (end_ptr - ptr)) {
                *path = strdup(end_ptr); // This would be the device name for rpcap
                if (!*path) {
                    snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for path");
                    free(*userinfo);
                    free(*host);
                    free(*port);
                    return -1;
                }
            }
        }
    } else {
        // If no scheme, treat the whole string as a local device path
        *path = strdup(source);
        if (!*path) {
            snprintf(errbuf, PCAP_ERRBUF_SIZE, "strdup failed for path");
            return -1;
        }
    }
