        fflush(stdout);
        pcap_close(handle);
        return 123;
    } else {
        // If result is >= 0, the call was successful.
        printf("Calling pcap_is_swapped success\n");
        fflush(stdout);
        if (result == 1) {
            printf("Packet byte order is swapped.\n");
            fflush(stdout);
        } else {
            printf("Packet byte order is not swapped.\n");
            fflush(stdout);
        }
    }

    // Clean up
    pcap_close(handle);
    printf("pcap_t handle closed.\n");
    fflush(stdout);

    return 0;
}


