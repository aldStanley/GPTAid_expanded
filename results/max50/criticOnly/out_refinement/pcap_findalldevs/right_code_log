#include <stdlib.h>
#include <pcap.h>

#define ERROR_BUFFER_SIZE 256
#define EXIT_FAILURE_CODE 123

int main() {
    pcap_if_t *alldevs = NULL;
    char errbuf[ERROR_BUFFER_SIZE];
    int status;

    // Add line before calling pcap_findalldevs
    printf("before pcap_findalldevs\n");
    fflush(stdout);

