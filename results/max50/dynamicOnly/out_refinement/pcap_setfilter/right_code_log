#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// Function to handle errors and exit
void handle_error(const char* message, pcap_t* handle, struct bpf_program* compiled_filter) {
    if (handle) {
        fprintf(stderr, "%s: %s\n", message, pcap_geterr(handle));
        pcap_close(handle);
    } else {
        fprintf(stderr, "%s\n", message);
    }
    if (compiled_filter) {
