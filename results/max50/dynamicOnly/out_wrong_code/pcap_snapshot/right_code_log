        // Task 2.3: Output error message
        fprintf(stderr, "pcap_snapshot failed: Capture handle is not activated.\n");
        fflush(stdout);
        pcap_close(handle);
        return 123;
    } else if (snapshot_len < 0) {
        // Task 2.5: Output "Calling pcap_snapshot fail"
        printf("Calling pcap_snapshot fail\n");
        fflush(stdout);
        // Task 2.3: Output error message
        fprintf(stderr, "pcap_snapshot failed with an unexpected negative value: %d\n", snapshot_len);
        fflush(stdout);
        pcap_close(handle);
        return 123;
    } else {
        // Task 2.5: Output "Calling pcap_snapshot success"
        printf("Calling pcap_snapshot success\n");
        fflush(stdout);
        printf("Snapshot length: %d\n", snapshot_len);
        fflush(stdout);
    }

    // Task 2.2: Non-interactive and no infinite loops.
    pcap_close(handle);
    printf("pcap_close succeeded.\n");
    fflush(stdout);

    return 0;
}
