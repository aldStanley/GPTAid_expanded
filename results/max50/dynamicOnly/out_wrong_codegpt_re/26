    // Apply the desired non-blocking option to the handle BEFORE activation
    // Note: pcap_open_live might have already tried to set non-blocking if it supports it.
    // pcap_activate will re-apply it if p->opt.nonblock is set.
    handle->opt.nonblock = 1; // Explicitly set it here

    // --- Step 2: Call pcap_activate ---
    printf("before pcap_activate\n");
    fflush(stdout); // Ensure "before pcap_activate" is printed immediately

    status = pcap_activate(handle);

    // --- Step 3: Check the status of pcap_activate ---
    if (status < 0) {
        // pcap_activate failed
        printf("Calling pcap_activate fail\n");
        fflush(stdout); // Flush stdout

        // The error message might be in handle->errbuf if it was set by pcap_activate,
        // or pcap_statustostr will provide a generic message if handle->errbuf is empty.
        if (handle->errbuf[0] != '\0') {
            fprintf(stderr, "pcap_activate failed with error: %s\n", handle->errbuf);
        } else {
            fprintf(stderr, "pcap_activate failed with status code %d: %s\n", status, pcap_statustostr(status));
        }
        fflush(stdout); // Flush stdout
        pcap_close(handle); // Clean up the handle
        return MY_CUSTOM_ERROR_CODE;
    } else {
        // pcap_activate succeeded
        printf("Calling pcap_activate success\n");
        fflush(stdout); // Flush stdout

        // If activate_op returns >= 0, and non-blocking was requested,
        // pcap_activate calls setnonblock_op. We can check if non-blocking is active.
        // The `p->setnonblock_op` would have been called by `pcap_activate`.
        // To verify non-blocking mode, you'd typically use `pcap_getnonblock`.
        int nonblock_status = pcap_getnonblock(handle, errbuf);
        if (nonblock_status == -1) {
            fprintf(stderr, "Error checking non-blocking status: %s\n", errbuf);
            fflush(stdout); // Flush stdout
            pcap_close(handle);
            return MY_CUSTOM_ERROR_CODE;
        } else if (nonblock_status == 1) {
            printf("Device is in non-blocking mode.\n");
            fflush(stdout);
        } else {
            printf("Device is NOT in non-blocking mode.\n");
            fflush(stdout);
        }

        // You can now proceed with capturing packets using this handle,
        // for example, using pcap_loop or pcap_next_ex.
        // For this example, we will just close the handle.
        printf("pcap_activate completed successfully.\n");
        fflush(stdout);
    }

    // --- Step 4: Clean up ---
    pcap_close(handle);
    printf("pcap handle closed.\n");
    fflush(stdout);

    return 0;
}
