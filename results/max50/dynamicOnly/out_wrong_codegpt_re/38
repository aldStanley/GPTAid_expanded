#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include <pcap.h>



int main() {
    pcap_t *handle = NULL;
    char errbuf[PCAP_ERRBUF_SIZE];
    const char *filename = "example.pcap"; // Requirement 7: file name

    // Create a dummy file for pcap_open_offline to read.
    // This ensures that pcap_open_offline has a file to attempt to open.
    printf("Creating a dummy file named %s.\n", filename);
    fflush(stdout);
    FILE *dummy_file = fopen(filename, "wb");
    if (dummy_file == NULL) {
        fprintf(stderr, "Failed to create dummy file %s: %s\n", filename, strerror(errno));
        fflush(stdout);
        return 123;
    }
    fclose(dummy_file);
    printf("Dummy file %s was created successfully.\n", filename);
    fflush(stdout);

    // Attempt to open the file for reading using pcap_open_offline.
    // This is the primary way to get a valid pcap_t* handle.
    printf("Attempting to open %s for offline capture.\n", filename);
    fflush(stdout);
    handle = pcap_open_offline(filename, errbuf);

    if (handle == NULL) {
        fprintf(stderr, "pcap_open_offline could not open %s: %s\n", filename, errbuf);
        fflush(stdout);
        // Clean up the dummy file if it was created
        if (remove(filename) != 0) {
            fprintf(stderr, "Error occurred while removing dummy file %s after open failure: %s\n", filename, strerror(errno));
            fflush(stdout);
        }
        return 123;
    }
    printf("pcap_open_offline successfully opened %s.\n", filename);
    fflush(stdout);

    // Requirement 6: Add specific output before calling pcap_close
    printf("before pcap_close\n");
    fflush(stdout);

    // Call the pcap_close function.
    // This function is responsible for cleaning up the resources associated with the pcap_t handle.
    pcap_close(handle);

    // Task2.5: Output success or failure message.
    // Since pcap_close is a void function and doesn't return an explicit status,
    // reaching this point without a crash implies success in its execution.
    // The actual failure of pcap_close would likely be a segmentation fault if 'handle' was invalid.
    printf("Calling pcap_close success\n");
    fflush(stdout);

    // Clean up the dummy file after successful operation
    if (remove(filename) != 0) {
        fprintf(stderr, "An error occurred while removing dummy file %s after pcap_close: %s\n", filename, strerror(errno));
        fflush(stdout);
        // This is a cleanup error, not necessarily a pcap_close failure.
        // We'll still return 0 as pcap_close itself succeeded.
    } else {
        printf("Dummy file %s was removed successfully.\n", filename);
        fflush(stdout);
    }

    return 0;
}



