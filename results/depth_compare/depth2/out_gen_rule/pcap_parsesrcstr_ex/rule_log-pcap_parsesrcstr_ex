printf("Unexpected error message: %s\n", errbuf);
}
} else {
// If the first call fails, errbuf will contain an error message.
fprintf(stderr, "Error parsing source: %s\n", errbuf);
}
// Second call with an invalid source. If the first call succeeded and errbuf wasn't cleared,
// the error message from this call might be appended to or overwrite old data in a way
// that's not immediately obvious if the caller isn't careful.
if (pcap_parsesrcstr_ex(source_invalid, &type, userinfo, host, port, name, &uses_ssl, errbuf) == -1) {
fprintf(stderr, "Error parsing source: %s\n", errbuf); // This error message is expected.
}
return 0;
}
