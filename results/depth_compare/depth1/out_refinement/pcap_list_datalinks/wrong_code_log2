            fprintf(stderr, "Error: datalinks pointer is NULL after successful call.\n");
            fflush(stdout);
        }
    } else {
        printf("Calling pcap_list_datalinks fail\n");
        fflush(stdout);
        fprintf(stderr, "pcap_list_datalinks failed: %s\n", errbuf);
        fflush(stdout);
    }

    // Close the capture device
