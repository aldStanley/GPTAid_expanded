/**
 * @brief Sets the snapshot length for a pcap handle.
 *
 * This function sets the snapshot length (snaplen) for a given pcap handle.
 * The snapshot length determines the maximum number of bytes to be captured
 * from each packet.
 *
 * @param p A pointer to the pcap_t structure representing the capture handle.
 * @param snaplen The desired snapshot length in bytes.
 *
 * @return 0 on success.
 * @return PCAP_ERROR_ACTIVATED if the capture device is already activated.
 *
 * @invocation_specification
 * The caller must ensure that the pcap handle `p` is valid and initialized.
 * The `pcap_set_snaplen` function must be called *before* the capture device
 * has been activated (e.g., before calling `pcap_open_live` or `pcap_activate`).
 * The `pcap_check_activated` function is called internally by `pcap_set_snaplen`
 * to verify that the capture has not been activated. If it has, `PCAP_ERROR_ACTIVATED`
 * is returned.
 * The `snaplen` parameter should be a non-negative integer.
 */
int pcap_set_snaplen(pcap_t *p, int snaplen){
	// Task 1: Invocation Specification Analysis
	// The function checks if the pcap handle `p` has already been activated
	// using `pcap_check_activated(p)`. If `pcap_check_activated` returns a
	// non-zero value (indicating activation), `pcap_set_snaplen` immediately
	// returns `PCAP_ERROR_ACTIVATED`.
	// Therefore, the caller must ensure that `pcap_set_snaplen` is called
	// *before* the pcap handle is activated.
	// The `pcap_t *p` must be a valid and initialized pcap handle.
	// The `int snaplen` represents the desired snapshot length and should be a
	// non-negative value.
	if (pcap_check_activated(p))
		return (PCAP_ERROR_ACTIVATED);
	p->snapshot = snaplen;
	return (0);
}

