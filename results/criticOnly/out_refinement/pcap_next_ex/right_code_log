        printf("Calling pcap_next_ex fail: Unexpected return 0 in offline capture.\n");
        fflush(stdout);
    } else { // result == -1
        fprintf(stderr, "Error in pcap_next_ex: %s\n", pcap_geterr(handle));
        printf("Calling pcap_next_ex fail\n");
        fflush(stdout);
    }

    pcap_close(handle);
    printf("Closed offline capture handle.\n");
    fflush(stdout);

