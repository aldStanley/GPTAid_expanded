        pcap_freecode(&fp); // Clean up compiled filter
        pcap_close(handle); // Clean up the handle
        printf("Calling pcap_setfilter fail\n");
        fflush(stdout);
        return 123;
    } else {
        printf("Calling pcap_setfilter success\n");
        fflush(stdout);
    }

    // 5. Clean up resources
