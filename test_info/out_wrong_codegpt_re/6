#include <pcap.h>
#include <stdio.h>
#include <stdlib.h>
#include <errno.h>

int main() {
    pcap_t *handle;
    char errbuf[PCAP_ERRBUF_SIZE];
    int major_version;

    // Task 2.2: Non-interactive, no infinite loops.
    // Task 2.1: Compilable and follows invocation specification.

    // Task 2.3: Check call status of each API.
    // Task 2.7: File name requirement (not directly applicable here as we're opening a device, but if a pcap file were involved, it would be example.pcap)

    // Open a network device. This is a prerequisite for pcap_major_version to work correctly
    // as it checks if the pcap handle is activated.
    handle = pcap_open_live("eth0", BUFSIZ, 1, 1000, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Error opening adapter: %s\n", errbuf);
        fflush(stdout);
        return 123;
    }
    printf("pcap_open_live success\n");
    fflush(stdout);

    // Task 2.6: Add specific printf before calling pcap_major_version.
    printf("before pcap_major_version\n");
    fflush(stdout);

    // Task 1: Analyze the function code to find the invocation specification.
    // The function `pcap_major_version` expects a valid `pcap_t *` pointer `p`
    // that has been successfully activated. The check `!p->activated` implies
    // that `pcap_open_live` or `pcap_open_offline` (or similar activation functions)
    // must have been called successfully prior to calling `pcap_major_version`,
    // and the returned `pcap_t` pointer must not be NULL. If the handle is not
    // activated, it returns `PCAP_ERROR_NOT_ACTIVATED`.

    // Task 2.5: Output success/failure messages.
    major_version = pcap_major_version(handle);

    if (major_version >= 0) { // pcap_major_version returns >= 0 on success
        printf("Calling pcap_major_version success\n");
        fflush(stdout);
        printf("Major version: %d\n", major_version);
        fflush(stdout);
    } else {
        // Task 2.3: Infer cause of error.
        fprintf(stderr, "Calling pcap_major_version fail: returned %d (PCAP_ERROR_NOT_ACTIVATED)\n", major_version);
        fflush(stdout);
        // Task 2.3: Return specific error code.
        return 123;
    }

    // Clean up the pcap handle.
    pcap_close(handle);
    printf("pcap_close success\n");
    fflush(stdout);

    return 0;
}
