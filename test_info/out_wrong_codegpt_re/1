#include <pcap.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    pcap_t *handle;
    char errbuf[PCAP_ERRBUF_SIZE];
    const char *device = pcap_lookupdev(errbuf);

    if (device == NULL) {
        fprintf(stderr, "Couldn't find default device: %s\n", errbuf);
        fflush(stdout);
        return 123;
    }

    // Open the session in promiscuous mode
    handle = pcap_open_live(device, BUFSIZ, 1, 1000, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Couldn't open device %s: %s\n", device, errbuf);
        fflush(stdout);
        return 123;
    }

    // Activate the pcap session
    int activate_status = pcap_activate(handle);
    if (activate_status < 0) {
        fprintf(stderr, "Error activating the session: %s\n", pcap_geterr(handle));
        fflush(stdout);
        pcap_close(handle);
        return 123;
    }

    // Check if the session is actually activated before calling pcap_snapshot
    // Although pcap_activate returns success, it's good practice to be sure
    // pcap_snapshot itself checks this, but the explicit check helps in debugging.
    if (!handle->activated) {
        fprintf(stderr, "The pcap session was not activated after pcap_activate call.\n");
        fflush(stdout);
        pcap_close(handle);
        return 123;
    }

    printf("before pcap_snapshot\n");
    fflush(stdout);

    // Call the pcap_snapshot function
    int snapshot_len = pcap_snapshot(handle);

    // pcap_snapshot returns the snapshot length or PCAP_ERROR_NOT_ACTIVATED if not activated.
    // PCAP_ERROR_NOT_ACTIVATED is typically -1.
    if (snapshot_len < 0 && snapshot_len != PCAP_ERROR_NOT_ACTIVATED) {
        fprintf(stderr, "Calling pcap_snapshot fail: Unknown error code %d\n", snapshot_len);
        fflush(stdout);
    } else if (snapshot_len == PCAP_ERROR_NOT_ACTIVATED) {
        fprintf(stderr, "Calling pcap_snapshot fail: pcap_t not activated.\n");
        fflush(stdout);
    }
    else {
        printf("Calling pcap_snapshot success\n");
        fflush(stdout);
        printf("Snapshot length obtained: %d\n", snapshot_len);
        fflush(stdout);
    }

    // Close the session
    pcap_close(handle);

    return 0;
}
