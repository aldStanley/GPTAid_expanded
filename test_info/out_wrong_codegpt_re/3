#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include <pcap.h>


int main() {
    pcap_t *handle = NULL;
    char errbuf[PCAP_ERRBUF_SIZE];
    int snapshot_len;
    pcap_if_t *alldevs;
    pcap_if_t *dev;
    char *selected_dev_name = NULL;

    // Attempt to find all network devices
    if (pcap_findalldevs(&alldevs, errbuf) == -1) {
        fprintf(stderr, "Error in pcap_findalldevs: %s\n", errbuf);
        fflush(stdout);
        printf("Error finding network devices.\n");
        fflush(stdout);
        return 123;
    }
    printf("Found network devices.\n");
    fflush(stdout);

    // Try to select a suitable device. Prioritize non-loopback, then any.
    // For a non-interactive test, we just pick the first one found that isn't loopback,
    // or the very first if only loopback is available.
    dev = alldevs;
    while (dev != NULL) {
        // Prefer non-loopback devices if possible
        if (!(dev->flags & PCAP_IF_LOOPBACK)) {
            selected_dev_name = dev->name;
            break;
        }
        if (selected_dev_name == NULL) { // If we haven't found a non-loopback, store the first one
            selected_dev_name = dev->name;
        }
        dev = dev->next;
    }

    if (selected_dev_name == NULL) {
        fprintf(stderr, "No network devices found.\n");
        fflush(stdout);
        printf("No network devices available to open.\n");
        fflush(stdout);
        pcap_freealldevs(alldevs); // Free the list of devices
        return 123;
    }

    printf("Selected device for capture: %s\n", selected_dev_name);
    fflush(stdout);

    // 1. Open a network device.
    // We use the selected device name, set snapshot length to a reasonable default,
    // promiscuous mode to 1, and a timeout.
    handle = pcap_open_live(selected_dev_name, BUFSIZ, 1, 1000, errbuf);
    if (handle == NULL) {
        fprintf(stderr, "Could not open device %s: %s\n", selected_dev_name, errbuf);
        fflush(stdout);
        printf("Failed to open network device.\n");
        fflush(stdout);
        pcap_freealldevs(alldevs); // Free the list of devices
        return 123;
    }
    printf("pcap_open_live successful for device %s.\n", selected_dev_name);
    fflush(stdout);

    // Free the list of devices as we no longer need it
    pcap_freealldevs(alldevs);

    // 2. Call pcap_snapshot
    printf("before pcap_snapshot\n");
    fflush(stdout);

    // This is the critical call to pcap_snapshot
    snapshot_len = pcap_snapshot(handle);

    if (snapshot_len == PCAP_ERROR_NOT_ACTIVATED) {
        fprintf(stderr, "Error: pcap_snapshot called on a non-activated pcap handle. "
                        "Ensure pcap_activate was successful.\n");
        fflush(stdout);
        printf("Calling pcap_snapshot fail\n");
        fflush(stdout);
        pcap_close(handle);
        return 123;
    } else if (snapshot_len < 0) {
        // pcap_snapshot is documented to return PCAP_ERROR_NOT_ACTIVATED or the snapshot length.
        // Any other negative value would be an unexpected error from the library itself.
        fprintf(stderr, "An unexpected negative value returned by pcap_snapshot: %d\n", snapshot_len);
        fflush(stdout);
        printf("Calling pcap_snapshot fail\n");
        fflush(stdout);
        pcap_close(handle);
        return 123;
    }

    // 3. If successful
    printf("Calling pcap_snapshot success\n");
    fflush(stdout);
    printf("Snapshot length is: %d\n", snapshot_len);
    fflush(stdout);

    // 4. Clean up
    pcap_close(handle);
    printf("pcap_close successful.\n");
    fflush(stdout);

    return 0;
}



